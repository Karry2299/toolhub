[Unit]
Description=ToolHub Django Application
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/toolhub
EnvironmentFile=/var/www/toolhub/.env
ExecStart=/var/www/toolhub/.venv/bin/gunicorn config.wsgi:application --bind 127.0.0.1:8000 --workers 2 --timeout 1800 --worker-class sync
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
