# Django
DJANGO_SECRET_KEY=your-secret-key-here-change-this-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.railway.app,.onrender.com,yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://*.railway.app,https://*.onrender.com,https://yourdomain.com
DJANGO_CORS_ORIGINS=https://*.railway.app,https://*.onrender.com,https://yourdomain.com

# Database (PostgreSQL) - Railway/Render will auto-set this
DATABASE_URL=

# 管理员账号（首次部署用）
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin123
DJANGO_SUPERUSER_EMAIL=admin@example.com
