.head {
  margin-bottom: 22rpx;
}

.mini-btn {
  width: 132rpx;
  height: 66rpx;
  line-height: 66rpx;
  color: #ffffff;
  background: #0f172a;
  border-radius: 14rpx;
  font-size: 26rpx;
}

.editor {
  padding: 22rpx;
  margin-bottom: 22rpx;
}

.editor .input,
.editor .textarea {
  margin-bottom: 16rpx;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.note {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.note-title {
  font-size: 31rpx;
  font-weight: 750;
  margin-bottom: 8rpx;
}

.preview {
  line-height: 1.5;
}

.footer {
  margin-top: 16rpx;
  color: #94a3b8;
  font-size: 23rpx;
}

.delete {
  color: #ef4444;
}

.empty {
  text-align: center;
  color: #94a3b8;
  padding: 80rpx 0;
}
