.hero {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.hello {
  color: #64748b;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.hero-mark {
  width: 96rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 24rpx;
  text-align: center;
  color: #f59e0b;
  background: #0f172a;
  font-size: 42rpx;
  font-weight: 900;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.quick {
  min-height: 190rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.icon {
  font-size: 46rpx;
  margin-bottom: 16rpx;
}

.name {
  font-weight: 750;
  margin-bottom: 6rpx;
}

.desc {
  font-size: 23rpx;
  line-height: 1.35;
}
