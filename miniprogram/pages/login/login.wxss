.login-page {
  min-height: 100vh;
  padding-top: 100rpx;
}

.brand {
  text-align: center;
  margin-bottom: 42rpx;
}

.logo {
  width: 104rpx;
  height: 104rpx;
  line-height: 104rpx;
  margin: 0 auto 18rpx;
  border-radius: 26rpx;
  color: #f59e0b;
  background: #0f172a;
  font-size: 44rpx;
  font-weight: 900;
}

.form-card {
  padding: 28rpx;
}

.segmented {
  display: flex;
  padding: 6rpx;
  margin-bottom: 24rpx;
  border-radius: 18rpx;
  background: #f1f5f9;
}

.seg {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 14rpx;
  color: #64748b;
  font-weight: 650;
}

.seg.active {
  color: #0f172a;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.08);
}

.input {
  margin-bottom: 18rpx;
}

.tip {
  margin-top: 26rpx;
  color: #94a3b8;
  text-align: center;
  font-size: 24rpx;
}
