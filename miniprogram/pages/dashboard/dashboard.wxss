.head-sub {
  margin: 8rpx 0 22rpx;
}

.stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.stat {
  padding: 24rpx;
}

.value {
  font-size: 42rpx;
  font-weight: 850;
}

.panel {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.panel-title {
  font-weight: 750;
  margin-bottom: 14rpx;
}

.row-item {
  padding: 16rpx 0;
  border-top: 1rpx solid #eef2f7;
}

.empty {
  color: #94a3b8;
  padding: 18rpx 0;
}
