.head-sub { margin: 8rpx 0 22rpx; }
.panel { padding: 24rpx; }
.password { min-height: 90rpx; line-height: 1.4; padding: 22rpx; margin-bottom: 16rpx; border-radius: 16rpx; background: #f8fafc; font-family: monospace; font-size: 30rpx; word-break: break-all; text-align: center; }
.checks { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14rpx; margin: 16rpx 0; color: #475569; }
.actions { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; margin-top: 16rpx; }
.section { margin: 28rpx 0 14rpx; font-weight: 750; }
.saved { padding: 20rpx; margin-bottom: 14rpx; }
.saved-pwd { margin-bottom: 12rpx; font-family: monospace; word-break: break-all; }
.copy { color: #f59e0b; }
