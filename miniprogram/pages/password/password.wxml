<view class="page">
  <view class="title">密码生成器</view>
  <view class="subtle head-sub">生成并保存随机密码</view>
  <view class="card panel">
    <view class="password">{{password || '点击生成密码'}}</view>
    <slider min="6" max="64" value="{{length}}" show-value bindchange="onLength" activeColor="#f59e0b" />
    <view class="checks">
      <label><checkbox checked="{{upper}}" data-key="upper" bindtap="toggleOption" /> 大写</label>
      <label><checkbox checked="{{lower}}" data-key="lower" bindtap="toggleOption" /> 小写</label>
      <label><checkbox checked="{{digits}}" data-key="digits" bindtap="toggleOption" /> 数字</label>
      <label><checkbox checked="{{symbols}}" data-key="symbols" bindtap="toggleOption" /> 符号</label>
    </view>
    <input class="input" placeholder="备注，可选" value="{{note}}" bindinput="onNote" />
    <view class="actions">
      <button class="btn btn-ghost" bindtap="copyPassword">复制</button>
      <button class="btn btn-accent" bindtap="generate">生成</button>
      <button class="btn btn-primary" bindtap="savePassword">保存</button>
    </view>
  </view>
  <view class="section">已保存</view>
  <view class="saved card" wx:for="{{saved}}" wx:key="id">
    <view class="saved-pwd">{{item.password}}</view>
    <view class="between">
      <text class="subtle">{{item.note || item.created_at_text}}</text>
      <text class="copy" data-value="{{item.password}}" bindtap="copySaved">复制</text>
    </view>
  </view>
</view>
