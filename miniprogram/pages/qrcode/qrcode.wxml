<view class="page">
  <view class="title">二维码生成</view>
  <view class="subtle head-sub">把文字或链接生成二维码</view>
  <view class="card panel">
    <textarea class="textarea" placeholder="输入文本或链接" value="{{text}}" bindinput="onText"></textarea>
    <button class="btn btn-accent" bindtap="generate">生成二维码</button>
  </view>
  <view class="card result" wx:if="{{qrUrl}}">
    <image class="qr" src="{{qrUrl}}" mode="aspectFit" show-menu-by-longpress />
    <view class="subtle">长按图片可保存或分享</view>
  </view>
  <view class="section">历史记录</view>
  <view class="record card" wx:for="{{records}}" wx:key="id">
    <view>{{item.content}}</view>
    <view class="subtle">{{item.created_at_text}}</view>
  </view>
</view>
